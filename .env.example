# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VidSaaS
NODE_ENV=development

# Database - local docker-compose default
DATABASE_URL=file:/app/prisma/prod.db

# API key hashing pepper - change in production and keep secret
API_KEY_PEPPER=replace-with-a-long-random-secret

# Local demo auth allows dashboard API-key creation using an email field.
# Turn OFF in production and integrate Auth.js/Clerk/Supabase or your own session layer.
ALLOW_DEMO_AUTH=true
ADMIN_SECRET=replace-admin-secret

# yt-dlp / FFmpeg binaries. Dockerfile installs these system-wide.
YTDLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg
YTDLP_TIMEOUT_MS=60000
YTDLP_MAX_FILESIZE=2G

# Optional: TeraBox links may require a valid ndus cookie for restricted/verified files.
TERABOX_COOKIE=

# Optional DigitalPlat FreeDomain target
PUBLIC_DOMAIN=your-name.dpdns.org
